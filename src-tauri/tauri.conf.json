{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TrueClean",
  "version": "0.1.0",
  "identifier": "com.trueclean.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "TrueClean",
        "width": 1280,
        "height": 832,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Cross-platform disk cleaner with an AI agent",
    "longDescription": "TrueClean scans your disk, visualizes usage, identifies junk and system data, and lets an AI agent recommend and perform safe cleanups."
  }
}
