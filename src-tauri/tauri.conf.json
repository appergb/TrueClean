{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TrueClean",
  "version": "0.1.0",
  "identifier": "com.trueclean.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "TrueClean",
        "width": 1280,
        "height": 832,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/[email protected]",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Cross-platform disk cleaner with an AI agent",
    "longDescription": "TrueClean scans your disk, visualizes usage, identifies junk and system data, and lets an AI agent recommend and perform safe cleanups.",
    "macOS": {
      "infoPlist": "Info.plist",
      "entitlements": "TrueClean.entitlements"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDMTA2NkQ5MThGRTk3NkQKUldSdGwvNFkyV1lRekFEUWN0dTRtYm1xMTdFWHhzRlZGeGdSbTZjZjVXUlphZndsd0NjY0ZnemIK",
      "endpoints": [
        "https://github.com/appergb/TrueClean/releases/latest/download/latest.json"
      ]
    }
  }
}
